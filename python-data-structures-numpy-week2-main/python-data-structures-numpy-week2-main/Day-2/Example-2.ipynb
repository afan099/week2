   "source": [
    "# Check whether a word reads the same forward and backward(Palindrome).\n",
    "\n",
    "word = \"madam\"\n",
    "\n",
    "if word == word[::-1]:\n",
    "    print(\"Palindrome\")\n",
    "else:\n",
    "    print(\"Not a palindrome\")"
   ]
