   "source": [
    "import numpy as np\n",
    "\n",
    "matrix = np.array([\n",
    "    [10, 20, 30],\n",
    "    [40, 50, 60],\n",
    "    [70, 80, 90]\n",
    "])\n",
    "\n",
    "print(\"Row sums:\", np.sum(matrix, axis=1))\n",
    "print(\"Column sums:\", np.sum(matrix, axis=0))\n",
    "\n",
    "# Purpose: Shows aggregation across rows and columns."
   ]
  }
 ],
