    "import numpy as np\n",
    "\n",
    "scores = np.array([78, 85, 90, 66, 88])\n",
    "\n",
    "print(\"Maximum score:\", np.max(scores))\n",
    "print(\"Minimum score:\", np.min(scores))\n",
    "print(\"Standard deviation:\", np.std(scores))\n",
    "\n",
    "# Purpose: Finds spread and extremes in a dataset."
   ]
