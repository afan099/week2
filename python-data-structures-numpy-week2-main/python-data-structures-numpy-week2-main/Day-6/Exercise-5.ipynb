    "# Random Sampling Example\n",
    "\n",
    "import numpy as np\n",
    "import random\n",
    "\n",
    "students = np.array([\"Alice\", \"Bob\", \"Charlie\", \"David\", \"Eva\"])\n",
    "\n",
    "sample = np.random.choice(students, 3)\n",
    "\n",
    "print(\"Randomly Selected Students:\", sample)"
   ]
  }
