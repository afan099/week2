   "source": [
    "# Stacking Arrays (Vertical Stack)\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "a = np.array([1, 2, 3])\n",
    "b = np.array([4, 5, 6])\n",
    "\n",
    "stacked = np.vstack((a, b))\n",
    "\n",
    "print(\"Vertical Stack:\")\n",
    "print(stacked)"
   ]
  }
 ],
