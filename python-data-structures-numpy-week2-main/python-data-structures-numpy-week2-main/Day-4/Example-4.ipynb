   "source": [
    "# Reshaping Arrays (1D -> 2D)\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "arr = np.array([1, 2, 3, 4, 5, 6])\n",
    "\n",
    "reshaped = arr.reshape(2, 3)\n",
    "\n",
    "print(\"Reshaped Array:\")\n",
    "print(reshaped)"
   ]
  }
