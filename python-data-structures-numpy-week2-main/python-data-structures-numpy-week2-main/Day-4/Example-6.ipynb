   "source": [
    "# Concatenating Arrays\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "arr1 = np.array([1, 2, 3])\n",
    "arr2 = np.array([4, 5, 6])\n",
    "\n",
    "combined = np.concatenate((arr1, arr2))\n",
    "\n",
    "print(\"Concatenated Array:\", combined)"
   ]
  }
 ],
