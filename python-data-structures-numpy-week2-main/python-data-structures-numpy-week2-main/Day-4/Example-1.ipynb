   "source": [
    "# Array Indexing and Slicing in NumPy\n",
    "import numpy as np\n",
    "\n",
    "arr = np.array([10, 20, 30, 40, 50])\n",
    "print(\"Array:\", arr)\n",
    "\n",
    "# Array Indexing\n",
    "print(\"First element:\", arr[0])\n",
    "print(\"Third element:\", arr[2])\n",
    "\n",
    "# Array Slicing\n",
    "print(\"Elements from index 1 to 3:\", arr[1:4]) "
   ]
  }
 ],
